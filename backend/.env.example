# ==============================================================
# RetailPulse Server – Environment Variables
# ==============================================================

# Application
APP_NAME=RetailPulse API
APP_VERSION=2.0.0
DEBUG=false

# Database (switch to postgres for production)
# For CSV mode (default, works immediately):
DATA_MODE=csv
DATABASE_URL=sqlite:///./retailpulse.db

# For PostgreSQL / Supabase:
# DATA_MODE=postgres
# DATABASE_URL=postgresql://user:password@host:5432/retailpulse

# JWT Authentication
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
