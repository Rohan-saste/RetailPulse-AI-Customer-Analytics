# RetailPulse Environment Variables
# Copy this file to `.env` and fill in the values

# Backend App Config
APP_NAME="RetailPulse Enterprise API"
APP_VERSION="2.0.4"
API_PREFIX="/api/v1"
CORS_ORIGINS="*"

# Authentication
SECRET_KEY="replace_with_your_secure_secret_key"
ACCESS_TOKEN_EXPIRE_MINUTES="1440"

# Database Config (SQLite default)
DATABASE_URL="sqlite:///./retailpulse.db"
